<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Olivium Estate Brochure</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    font-family: 'Georgia', 'Times New Roman', serif;
    background: #f5f0e8;
    color: #1a1a1a;
  }
  
  /* Page setup for PDF */
  .page {
    width: 210mm;
    min-height: 297mm;
    margin: 0 auto 20px;
    padding: 15mm 18mm;
    background: #ffffff;
    box-shadow: 0 0 20px rgba(0,0,0,0.1);
    page-break-after: always;
    position: relative;
    overflow: hidden;
  }
  
  /* Print styles */
  @media print {
    body { background: white; }
    .page {
      width: 100%;
      margin: 0;
      padding: 15mm 18mm;
      box-shadow: none;
      page-break-after: always;
      min-height: 100vh;
    }
    .no-print { display: none; }
  }
  
  @page {
    size: A4;
    margin: 0;
  }
  
  /* Typography */
  h1 {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #4a6b1e;
    font-family: 'Georgia', serif;
  }
  
  h2 {
    font-size: 28px;
    font-weight: 400;
    color: #4a6b1e;
    font-family: 'Georgia', serif;
    margin-bottom: 10px;
  }
  
  h3 {
    font-size: 18px;
    font-weight: 600;
    color: #4a6b1e;
    font-family: 'Georgia', serif;
  }
  
  .gold-text { color: #C5A059; }
  .green-text { color: #4a6b1e; }
  
  .subtitle {
    font-size: 14px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #C5A059;
    margin-bottom: 8px;
  }
  
  /* Layout */
  .hero-section {
    text-align: center;
    padding: 40px 0 30px;
    border-bottom: 2px solid #C5A059;
  }
  
  .hero-section .estate-name {
    font-size: 14px;
    letter-spacing: 8px;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 5px;
  }
  
  .hero-section h1 {
    font-size: 52px;
    margin-bottom: 8px;
  }
  
  .hero-section .tagline {
    font-size: 18px;
    font-style: italic;
    color: #666;
    margin-top: 5px;
  }
  
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin: 25px 0;
  }
  
  .three-col {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin: 20px 0;
  }
  
  .feature-box {
    background: #f8f5ef;
    padding: 20px;
    border-radius: 8px;
    border-left: 3px solid #C5A059;
  }
  
  .feature-box h3 {
    margin-bottom: 6px;
  }
  
  .feature-box p {
    font-size: 13px;
    line-height: 1.6;
    color: #444;
  }
  
  .img-placeholder {
    background: #e8e4dc;
    border-radius: 8px;
    overflow: hidden;
    margin: 10px 0;
    text-align: center;
  }
  
  .img-placeholder img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .img-placeholder .caption {
    font-size: 11px;
    color: #888;
    padding: 6px;
    font-style: italic;
  }
  
  .divider {
    width: 60px;
    height: 2px;
    background: #C5A059;
    margin: 20px auto;
  }
  
  /* Membership tiers mini */
  .tier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 12px;
    margin: 15px 0;
  }
  
  .tier-box {
    background: #f8f5ef;
    padding: 15px 12px;
    border-radius: 6px;
    text-align: center;
    border: 1px solid #e8e4dc;
  }
  
  .tier-box .name {
    font-weight: 700;
    font-size: 14px;
    color: #4a6b1e;
  }
  
  .tier-box .price {
    font-size: 20px;
    font-weight: 700;
    color: #C5A059;
    margin: 4px 0;
  }
  
  .tier-box .desc {
    font-size: 11px;
    color: #666;
    line-height: 1.4;
  }
  
  .tier-box.featured {
    border-color: #C5A059;
    background: #f5f0e8;
  }
  
  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin: 20px 0;
    text-align: center;
  }
  
  .stat-item .number {
    font-size: 32px;
    font-weight: 700;
    color: #4a6b1e;
    font-family: 'Georgia', serif;
  }
  
  .stat-item .label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #888;
  }
  
  /* Comparison table */
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    margin: 15px 0;
    font-size: 13px;
  }
  
  .compare-table th {
    background: #4a6b1e;
    color: white;
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
  }
  
  .compare-table th:first-child {
    background: #3a5a18;
  }
  
  .compare-table td {
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
  }
  
  .compare-table tr:nth-child(even) td {
    background: #faf8f4;
  }
  
  .check { color: #4a6b1e; font-weight: 700; }
  .x { color: #ccc; }
  
  /* Footer */
  .footer {
    position: absolute;
    bottom: 12mm;
    left: 18mm;
    right: 18mm;
    border-top: 1px solid #ddd;
    padding-top: 12px;
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: #999;
    letter-spacing: 1px;
  }
  
  .footer .logo {
    font-weight: 700;
    color: #4a6b1e;
    font-size: 13px;
  }
  
  /* Utility */
  .text-center { text-align: center; }
  .mt-10 { margin-top: 10px; }
  .mt-20 { margin-top: 20px; }
  .mb-10 { margin-bottom: 10px; }
  .mb-20 { margin-bottom: 20px; }
  .pt-20 { padding-top: 20px; }
  
  /* Print button */
  .print-btn {
    display: inline-block;
    background: #4a6b1e;
    color: white;
    padding: 12px 30px;
    border: none;
    border-radius: 30px;
    font-size: 14px;
    cursor: pointer;
    margin: 20px auto;
    text-align: center;
    font-weight: 600;
    letter-spacing: 1.5px;
  }
  
  .print-btn:hover {
    background: #3a5a18;
  }
  
  .print-wrapper {
    text-align: center;
    padding: 20px;
  }
  
  @media print {
    .print-wrapper { display: none; }
  }
</style>
</head>
<body>

<!-- PRINT BUTTON -->
<div class="print-wrapper no-print">
  <button class="print-btn" onclick="window.print()">📄 Download PDF Brochure</button>
  <p style="color:#666; font-size:13px; margin-top:8px;">Click the button above to save as PDF (3 pages)</p>
</div>

<!-- ============================================================ -->
<!-- PAGE 1: COVER + INTRO                                         -->
<!-- ============================================================ -->
<div class="page">
  
  <div class="hero-section">
    <div class="estate-name">Private Tuscan Estate</div>
    <h1>OLIVIUM</h1>
    <div class="divider"></div>
    <div class="tagline">A Place To Return To</div>
  </div>

  <!-- Hero Image -->
  <div class="img-placeholder" style="margin: 15px 0 5px;">
    <img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/villa.png" alt="Olivium Estate Villa">
    <div class="caption">San Vincenzo, Tuscany — A Private Luxury Estate</div>
  </div>

  <p style="font-size:15px; line-height:1.7; color:#333; margin:15px 0 10px; text-align:center; font-style:italic;">
    "Become part of a living olive estate. Experience Tuscany through stewardship, harvest traditions and luxury residency."
  </p>

  <div class="divider"></div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat-item">
      <div class="number">240</div>
      <div class="label">Olive Trees</div>
    </div>
    <div class="stat-item">
      <div class="number">50+</div>
      <div class="label">Years of Tradition</div>
    </div>
    <div class="stat-item">
      <div class="number">€450</div>
      <div class="label">Member Nightly Rate</div>
    </div>
    <div class="stat-item">
      <div class="number">1.8</div>
      <div class="label">Estate Hectares</div>
    </div>
    <div class="stat-item">
      <div class="number">4</div>
      <div class="label">Membership Tiers</div>
    </div>
  </div>

  <!-- Two column intro -->
  <div class="two-col">
    <div>
      <h2>Founder Story</h2>
      <div style="width:40px; height:2px; background:#C5A059; margin:8px 0;"></div>
      <p style="font-size:13.5px; line-height:1.7; color:#444;">
        Olivium began with a single question: what if the people who cared most about a place could share in its stewardship? 
        After years working across Tuscany's estate tourism and oil sector, our founder sought a model that was neither ownership 
        nor tourism — but something richer.
      </p>
      <p style="font-size:13.5px; line-height:1.7; color:#444; margin-top:10px; font-style:italic; color:#C5A059;">
        "We wanted a place where returning felt like belonging. Not checking in — but coming home."
      </p>
      <p style="font-size:13px; color:#666; margin-top:6px;">— Riccardo Taborelli, Founder</p>
    </div>
    <div>
      <div class="img-placeholder">
        <img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/grovedrone1.png" alt="Olive Grove">
        <div class="caption">The olive groves of San Vincenzo</div>
      </div>
    </div>
  </div>

  <div class="footer">
    <span class="logo">OLIVIUM</span>
    <span>Private Estate · San Vincenzo, Tuscany</span>
    <span>olivium.io</span>
  </div>
</div>

<!-- ============================================================ -->
<!-- PAGE 2: THE ESTATE + MIGNOLE STORY + OIL                      -->
<!-- ============================================================ -->
<div class="page">

  <h2 style="text-align:center; font-size:32px;">The Estate</h2>
  <div class="divider" style="margin:8px auto;"></div>
  
  <p style="text-align:center; font-size:14px; color:#555; max-width:500px; margin:0 auto 15px;">
    Beautiful land of olive groves, a Low Carbon Luxury villa, private pool, terrace dining — set among one of the most beautiful landscapes in Italy.
  </p>

  <!-- Estate Grid -->
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin:10px 0;">
    <div class="img-placeholder"><img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/dronevillaout.png" alt="Villa"><div class="caption">Villa Exterior</div></div>
    <div class="img-placeholder"><img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/dronevilla.png" alt="Aerial"><div class="caption">Aerial View</div></div>
    <div class="img-placeholder"><img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/walk.png" alt="Grove"><div class="caption">Olive Grove Walk</div></div>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin:5px 0 10px;">
    <div class="img-placeholder"><img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/olives.jpeg" alt="Olives"><div class="caption">Harvest Season</div></div>
    <div class="img-placeholder"><img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&auto=format&fit=crop&q=75" alt="Dining"><div class="caption">Terrace Dining</div></div>
  </div>

  <div class="divider"></div>

  <!-- Mignole Story -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin:10px 0;">
    <div>
      <h3 style="font-size:20px;">The Mignole Story</h3>
      <div style="width:40px; height:2px; background:#C5A059; margin:6px 0;"></div>
      <p style="font-size:13px; line-height:1.7; color:#444;">
        Tiny flowering clusters — barely visible to the eye — carry the promise of an entire harvest. 
        Each <strong>mignole</strong> is a living bet on the season ahead. At Olivium, we trace everything back here. 
        Before the oil, before the bottle, before any of it: a blossom in the Tuscan spring.
      </p>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-top:12px; text-align:center;">
        <div><strong style="font-size:22px; color:#4a6b1e;">1</strong><br><span style="font-size:11px; color:#888;">Tree = 1,000,000 Mignoles</span></div>
        <div><strong style="font-size:22px; color:#4a6b1e;">240+</strong><br><span style="font-size:11px; color:#888;">Heritage Trees</span></div>
        <div><strong style="font-size:22px; color:#4a6b1e;">240M+</strong><br><span style="font-size:11px; color:#888;">Mignoles / Season</span></div>
      </div>
    </div>
    <div>
      <div class="img-placeholder">
        <img src="https://raw.githubusercontent.com/kyngrick/olivium_photos/main/mignole.jpeg" alt="Mignole">
        <div class="caption">The Mignole — where every harvest begins</div>
      </div>
    </div>
  </div>

  <div class="divider"></div>

  <!-- Olive Oil + Lab -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
    <div>
      <h3 style="font-size:20px;">Liquid Gold, Literally</h3>
      <div style="width:40px; height:2px; background:#C5A059; margin:6px 0;"></div>
      <p style="font-size:13px; line-height:1.7; color:#444;">
        Every harvest produces premium extra virgin olive oil from the estate's grove. Members receive annual allocations of cold-pressed, polyphenol-rich oil.
      </p>
      <ul style="font-size:12.5px; color:#555; line-height:1.8; margin-top:8px; list-style-type: none; padding:0;">
        <li style="padding:3px 0;">✓ High polyphenol content — independently lab-certified</li>
        <li style="padding:3px 0;">✓ Cold-pressed within 24 hours of harvest</li>
        <li style="padding:3px 0;">✓ Annual member allocations based on tier</li>
        <li style="padding:3px 0;">✓ Member tastings during residency visits</li>
      </ul>
    </div>
    <div>
      <div style="background:#f5f0e8; padding:15px; border-radius:8px; border:1px solid #e8e4dc;">
        <p style="font-size:11px; letter-spacing:3px; text-transform:uppercase; color:#C5A059; margin-bottom:8px;">Lab Report — 2024 Harvest</p>
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; text-align:center;">
          <div>
            <div style="font-size:28px; font-weight:700; color:#4a6b1e;">892</div>
            <div style="font-size:10px; color:#888; text-transform:uppercase; letter-spacing:1px;">Polyphenols mg/kg</div>
          </div>
          <div>
            <div style="font-size:28px; font-weight:700; color:#4a6b1e;">0.18%</div>
            <div style="font-size:10px; color:#888; text-transform:uppercase; letter-spacing:1px;">Acidity</div>
          </div>
          <div>
            <div style="font-size:28px; font-weight:700; color:#4a6b1e;">EVOO</div>
            <div style="font-size:10px; color:#888; text-transform:uppercase; letter-spacing:1px;">Classification</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="footer">
    <span class="logo">OLIVIUM</span>
    <span>Private Estate · San Vincenzo, Tuscany</span>
    <span>olivium.io</span>
  </div>
</div>

<!-- ============================================================ -->
<!-- PAGE 3: MEMBERSHIP + COMPARISON + CTA                         -->
<!-- ============================================================ -->
<div class="page">

  <h2 style="text-align:center; font-size:32px;">Membership Tiers</h2>
  <div class="divider" style="margin:8px auto;"></div>
  <p style="text-align:center; font-size:14px; color:#555; max-width:500px; margin:0 auto 15px;">
    Choose Your Role In The Estate
  </p>

  <!-- 4 Tiers -->
  <div class="tier-grid">
    <div class="tier-box">
      <div class="name">🌱 Mignole Supporter</div>
      <div class="price">€500</div>
      <div class="desc">Entry-level membership with olive credits and community access.</div>
    </div>
    <div class="tier-box">
      <div class="name">🌿 Tree Guardian</div>
      <div class="price">€2,000</div>
      <div class="desc">Adopt a named olive tree. Receive harvest yields and priority booking.</div>
    </div>
    <div class="tier-box featured">
      <div class="name">👑 Grove Patron</div>
      <div class="price">€10,000</div>
      <div class="desc">Full residency privileges, premium oil yields and private grove allocation.</div>
    </div>
    <div class="tier-box">
      <div class="name">🌲 Full Tree Estate</div>
      <div class="price">€20,000</div>
      <div class="desc">Complete stewardship, extended residency, and founding member privileges.</div>
    </div>
  </div>

  <div style="text-align:center; font-size:11px; color:#888; margin:-5px 0 10px;">
    ★ Grove Patron includes 7-Night Complimentary Stay
  </div>

  <div class="divider"></div>

  <!-- Comparison -->
  <h3 style="text-align:center; font-size:20px; margin-bottom:8px;">Membership vs. Traditional Villa</h3>
  <table class="compare-table">
    <thead>
      <tr>
        <th></th>
        <th>Traditional Tuscan Villa</th>
        <th style="background:#C5A059;">Olivium Residency</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>Nightly Cost</td><td>€800+</td><td><strong>€450</strong></td></tr>
      <tr><td>Annual Olive Oil</td><td><span class="x">✕</span></td><td><span class="check">✓ Included</span></td></tr>
      <tr><td>Harvest Access</td><td><span class="x">✕</span></td><td><span class="check">✓ Invited</span></td></tr>
      <tr><td>Estate Community</td><td><span class="x">✕</span></td><td><span class="check">✓ Members only</span></td></tr>
      <tr><td>Priority Booking</td><td><span class="x">✕</span></td><td><span class="check">✓ Annual window</span></td></tr>
      <tr><td>Stewardship Role</td><td><span class="x">✕</span></td><td><span class="check">✓ Your trees</span></td></tr>
      <tr><td>Olive Credits</td><td><span class="x">✕</span></td><td><span class="check">✓ Tradeable</span></td></tr>
    </tbody>
  </table>

  <div class="divider"></div>

  <!-- Harvest + CTA -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin:10px 0;">
    <div>
      <h3 style="font-size:18px;">Join The Harvest</h3>
      <div style="width:40px; height:2px; background:#C5A059; margin:6px 0;"></div>
      <p style="font-size:13px; line-height:1.7; color:#444;">
        Every autumn members are invited to take part in the annual olive harvest — one of the most grounding, joyful rituals of rural Tuscan life.
      </p>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:10px; font-size:12px;">
        <div style="background:#f8f5ef; padding:6px 10px; border-radius:4px;">🌿 Grove Inspection · Sep</div>
        <div style="background:#f8f5ef; padding:6px 10px; border-radius:4px;">🫒 Hand Picking · Oct</div>
        <div style="background:#f8f5ef; padding:6px 10px; border-radius:4px;">⚙️ Cold Pressing · Oct</div>
        <div style="background:#f8f5ef; padding:6px 10px; border-radius:4px;">🍶 Bottling & Tasting · Nov</div>
      </div>
    </div>
    <div style="background:#4a6b1e; color:white; padding:20px; border-radius:8px; text-align:center; display:flex; flex-direction:column; justify-content:center;">
      <p style="font-size:11px; letter-spacing:4px; text-transform:uppercase; opacity:0.7;">Estate Brochure</p>
      <h2 style="color:white; font-size:24px; margin:5px 0;">Download &amp; Explore</h2>
      <p style="font-size:13px; opacity:0.9; line-height:1.6; margin:8px 0;">
        Receive the complete Olivium residency brochure — including estate photography, membership details, harvest calendar and a full overview of the stewardship model.
      </p>
      <div style="margin-top:10px;">
        <span style="display:inline-block; background:#C5A059; color:#1a1a1a; padding:8px 20px; border-radius:30px; font-weight:700; font-size:13px; letter-spacing:1px;">
          📄 Download PDF Brochure
        </span>
      </div>
      <p style="font-size:10px; opacity:0.6; margin-top:8px;">olivium.io · San Vincenzo, Tuscany</p>
    </div>
  </div>

  <div class="footer">
    <span class="logo">OLIVIUM</span>
    <span>Private Estate · San Vincenzo, Tuscany</span>
    <span>olivium.io</span>
  </div>
</div>

<!-- ============================================================ -->
<!-- SCRIPTS                                                      -->
<!-- ============================================================ -->
<script>
  // Simple print trigger
  document.querySelector('.print-btn').addEventListener('click', function() {
    window.print();
  });
</script>

</body>
</html>
